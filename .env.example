# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mercado Pago (use as credenciais de SANDBOX por padrao)
# Sandbox: TEST-... | Producao: APP_USR-...
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000
# Chave secreta do webhook (Painel MP > Suas integracoes > Webhooks > Assinatura secreta)
MP_WEBHOOK_SECRET=your-webhook-secret

# Site
# Em desenvolvimento com ngrok, use a URL publica do ngrok (ex.: https://abcd-1234.ngrok-free.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin dashboard (senha simples)
ADMIN_PASSWORD=troque-esta-senha
